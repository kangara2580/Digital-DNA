generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// 판매 중인 영상(조각). 가격·조회·판매 수는 배치·수락 API에서 갱신됩니다.
model Video {
  id             String    @id @default(cuid())
  title          String
  creator        String
  src            String
  poster         String
  orientation    String
  durationSec    Int?
  price          Int
  views          Int       @default(0)
  salesCount     Int       @default(0) @map("sales_count")
  /// open | limited | private | batch
  editionKind    String    @default("open") @map("edition_kind")
  editionCap     Int?      @map("edition_cap")
  sellerId       String    @map("seller_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  flashSaleUntil DateTime? @map("flash_sale_until")
  /// 판매자 등록 시 설명(마켓 상세 연동용)
  description    String?
  /// 해시태그 — 쉼표 또는 공백 구분 저장(예: "#일상,#vlog")
  hashtags       String?
  /// AI 생성 여부(직접 촬영이면 false)
  isAiGenerated  Boolean   @default(false) @map("is_ai_generated")

  notifications Notification[]

  @@index([sellerId])
  @@index([createdAt])
  @@index([flashSaleUntil])
  @@map("videos")
}

/// 판매자 알림(가격 제안 등)
model Notification {
  id        String   @id @default(cuid())
  sellerId  String   @map("seller_id")
  type      String
  title     String
  body      String
  videoId   String   @map("video_id")
  oldPrice  Int      @map("old_price")
  newPrice  Int      @map("new_price")
  read      Boolean  @default(false)
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@index([videoId, type, status])
  @@map("notifications")
}

/// 닉네임 중복 방지용 예약 레코드 (대소문자 구분 없이 unique)
model NicknameReservation {
  id              String   @id @default(cuid())
  nickname        String   @unique
  displayNickname String   @map("display_nickname")
  reservedByEmail String?  @map("reserved_by_email")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("nickname_reservations")
}
