{
  "name": "digital-dna",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "predev": "fuser -k 3000/tcp || true",
    "dev": "next dev",
    "dev:safari": "node scripts/dev-open-safari.mjs",
    "dna": "npm run dev",
    "dev:3001": "next dev -p 3001 -H 127.0.0.1",
