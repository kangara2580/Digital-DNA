    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@supabase/supabase-js": "^2.103.0",
    "framer-motion": "^12.38.0",
