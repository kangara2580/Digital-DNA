{
  "name": "digital-dna",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "clean": "rm -rf .next .next-build",
    "predev": "node scripts/ensure-node-lts.mjs",
    "dev": "node scripts/dev-open-safari.mjs",
    "dev:safari": "node scripts/dev-open-safari.mjs",
    "dna": "npm run dev",
    "dev:3001": "next dev -p 3001 -H 127.0.0.1",
    "dev:turbo": "next dev --turbopack",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "next lint",
    "git:push": "git push origin main"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.103.3",
    "busboy": "^1.6.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "replicate": "^1.4.0",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
