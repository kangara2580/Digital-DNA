# prisma/schema.prisma 기준 상대 경로 → 실제 파일은 prisma/dev.db
DATABASE_URL="file:./dev.db"
CRON_SECRET="set-a-long-random-string-for-production"
NEXT_PUBLIC_DEMO_SELLER_ID="seller-demo"
SEED_SELLER_ID="seller-demo"
REPLICATE_API_TOKEN="r8_your_token_here"

# Supabase (회원가입/이메일 인증)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# TikTok Trending API skeleton
# 전체 URL을 넣어 주세요 (예: https://open.tiktokapis.com/v2/....)
TIKTOK_DISCOVERY_ENDPOINT="https://open.tiktokapis.com/v2/YOUR_ENDPOINT"
# Bearer 토큰
TIKTOK_ACCESS_TOKEN="YOUR_TIKTOK_ACCESS_TOKEN"
# true면 TikTok 실호출을 끄고 Mock 데이터만 사용 (승인 전 권장)
TIKTOK_USE_MOCK_ONLY="true"
