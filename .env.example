# prisma/schema.prisma 기준 상대 경로 → 실제 파일은 prisma/dev.db
DATABASE_URL="file:./dev.db"
CRON_SECRET="set-a-long-random-string-for-production"
NEXT_PUBLIC_DEMO_SELLER_ID="seller-demo"
SEED_SELLER_ID="seller-demo"
# Replicate — 배경 AI 미리보기(/api/transform) 등. https://replicate.com/account/api-tokens
# 빈 값으로 두지 마세요: REPLICATE_API_TOKEN="" 는 .env의 값까지 덮어씁니다. 미사용 시 줄 삭제.
REPLICATE_API_TOKEN="r8_your_token_here"
# (선택) 동일 토큰 — REPLICATE_API_TOKEN 이 비어 있을 때만 사용
# REPLICATE_TOKEN="r8_your_token_here"

# Supabase (회원가입/이메일 인증)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# 가입 직후 바로 로그인되게 하려면: Dashboard → Authentication → Providers → Email → Confirm email 끄기
# 세션은 브라우저 쿠키 + src/middleware.ts 로 갱신합니다. 배포 후 한 번 로그아웃했다가 다시 로그인하면
# 예전(localStorage-only) 세션이 남아 있어도 새 방식으로 맞춰집니다.

# 로컬 개발: 브라우저 주소와 아래 TikTok redirect URI 호스트를 반드시 하나로 맞추세요.
# http://localhost:3000 과 http://127.0.0.1:3000 은 서로 다른 사이트라 쿠키·로그인 상태가 갈라집니다.
# npm run dev 는 기본으로 127.0.0.1 에 바인딩합니다 — TikTok 콘솔 Login redirect URI 도 동일 호스트로 등록하세요.

# TikTok Research API — 인기영상 Top10 (video/query)
# 반드시 Research Tools 신청·승인 후 발급된 프로젝트의 Client Key/Secret만 사용
# (일반 Login Kit 앱 자격증명이면 OAuth는 되어도 video/query에서 scope_not_authorized 발생)
# https://developers.tiktok.com/research/
# 베이스만 넣어도 됨: https://open.tiktokapis.com/v2/ (자동으로 research/video/query로 보정)
TIKTOK_DISCOVERY_ENDPOINT="https://open.tiktokapis.com/v2/"
# client_credentials 토큰(직접 넣거나, 아래 CLIENT_KEY+SECRET으로 자동 발급)
TIKTOK_ACCESS_TOKEN="YOUR_TIKTOK_ACCESS_TOKEN"
TIKTOK_CLIENT_KEY="YOUR_CLIENT_KEY"
TIKTOK_CLIENT_SECRET="YOUR_CLIENT_SECRET"
# Login Kit OAuth 콜백 — 틱톡 개발자 콘솔의 Redirect URI 와 글자 하나까지 동일해야 합니다 (끝에 / 유무 포함).
# (선택) 비우면 요청 origin + /api/auth/tiktok/callback 이 쓰입니다.
# TIKTOK_REDIRECT_URI="http://127.0.0.1:3000/api/auth/tiktok/callback"
# Sandbox 앱이면: App → Sandbox → Target users 에 OAuth에 쓸 TikTok 계정을 추가해야 합니다. 없으면 non_sandbox_target 오류.
# 프로덕션 앱으로 승인된 키를 쓰면 위 샌드박스 대상 계정 제한이 없습니다.
# 쉼표 구분 지역 필터(비우면 keyword만 조회 — 샌드박스 권장)
TIKTOK_REGION_CODES=""
# 요청 fields (기본값 있음, 필요 시만 덮어쓰기)
# TIKTOK_RESEARCH_FIELDS="id,video_description,username,video_duration"
# true면 Mock만 사용 — 실제 TikTok 연동 시 반드시 false 또는 삭제
TIKTOK_USE_MOCK_ONLY="false"
