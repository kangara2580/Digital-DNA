# prisma/schema.prisma 기준 상대 경로 → 실제 파일은 prisma/dev.db
DATABASE_URL="file:./dev.db"
CRON_SECRET="set-a-long-random-string-for-production"
NEXT_PUBLIC_DEMO_SELLER_ID="seller-demo"
SEED_SELLER_ID="seller-demo"
# Replicate — 배경 AI 미리보기(/api/transform) 등. https://replicate.com/account/api-tokens
# 빈 값으로 두지 마세요: REPLICATE_API_TOKEN="" 는 .env의 값까지 덮어씁니다. 미사용 시 줄 삭제.
REPLICATE_API_TOKEN="r8_your_token_here"
# (선택) 동일 토큰 — REPLICATE_API_TOKEN 이 비어 있을 때만 사용
# REPLICATE_TOKEN="r8_your_token_here"

# Supabase (회원가입/이메일 인증)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# 서버 전용(비밀) — 로그인 아이디(이메일) 찾기 `/api/auth/find-email` 에만 사용. Git·프론트에 넣지 마세요.
# Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# --- Supabase 테이블 이름 (거의 항상 비워도 됨) ---
# 대시보드(Table Editor)에 보이는 public 테이블 이름이 아래 기본값과 다를 때만 설정합니다.
# 공백·괄호가 있어도 됩니다. 값에 공백이 있으면 따옴표로 감싸세요. SQL의 " 큰따옴표는 넣지 마세요.
# 기본값은 src/lib/supabaseTableNames.ts 를 보면 됩니다. snake_case로 바꿀 필요는 없습니다.
# NEXT_PUBLIC_SUPABASE_CART_TABLE="user_cart_items"
# NEXT_PUBLIC_SUPABASE_FAVORITES_TABLE="User Favorites (Wishlist/Likes) Table"
# NEXT_PUBLIC_SUPABASE_PROFILES_TABLE="User Profiles Table with RLS"
# NEXT_PUBLIC_SUPABASE_RECENT_VIEWS_TABLE="user_recent_views"
# NEXT_PUBLIC_SUPABASE_DEMO_PURCHASES_TABLE="user_demo_purchases"
# NEXT_PUBLIC_SUPABASE_CUSTOMIZE_DRAFTS_TABLE="user_customize_drafts"
# NEXT_PUBLIC_SUPABASE_DATA_BLOBS_TABLE="user_data_blobs"
# NEXT_PUBLIC_SUPABASE_SELLER_UPLOAD_DRAFTS_TABLE="seller_upload_drafts"
# NEXT_PUBLIC_SUPABASE_VIDEO_THUMBNAIL_SUMMARY_TABLE="Video Thumbnail Storage Summary"
# 가입 직후 바로 로그인되게 하려면: Dashboard → Authentication → Providers → Email → Confirm email 끄기
# 세션은 브라우저 쿠키 + src/middleware.ts 로 갱신합니다. 배포 후 한 번 로그아웃했다가 다시 로그인하면
# 예전(localStorage-only) 세션이 남아 있어도 새 방식으로 맞춰집니다.
# SMS 인증(Twilio Verify) — 회원가입/비밀번호 찾기/이메일 찾기용
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# (선택) SMS 인증 proof 서명용. 비우면 TIKTOK_SESSION_SECRET 또는 SUPABASE_SERVICE_ROLE_KEY를 사용.
# SMS_VERIFICATION_SECRET="long-random-secret"

# 홈 「실시간 인기순위」수동 TikTok URL (선택). 비우면 src/data/tiktokData.ts 의 파일 배열만 사용.
# 값은 JSON 배열 문자열: [{"id":1,"url":"https://www.tiktok.com/@handle/video/123..."}, ...]
# 상세는 src/data/tiktokData.ts 상단 주석 참고.
# NEXT_PUBLIC_TRENDING_TIKTOK_URLS='[{"id":1,"url":"https://www.tiktok.com/@example/video/7123456789012345678"}]'

# Google Cloud (console.cloud.google.com) — .env.local 에 실제 값만 넣고 커밋하지 마세요.
# Supabase Auth → Google: Client ID / Client Secret 은 대시보드에 입력. 로컬 참고용으로 아래에도 보관 가능.
# GOOGLE_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"
# YouTube Data API v3 등 (선택)
# GOOGLE_YOUTUBE_API_KEY="your-api-key"
# Gemini — reelsGenerate 등 (선택)
# GEMINI_API_KEY="your-gemini-key"

# TikTok OAuth / Trending 연동 (선택)
# TIKTOK_CLIENT_KEY="your_tiktok_client_key"
# TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"
# TIKTOK_REDIRECT_URI="http://localhost:3000/api/auth/tiktok/callback"
# TIKTOK_SESSION_SECRET="long-random-secret-for-cookie-encryption"
# TIKTOK_OAUTH_SCOPE="user.info.basic,video.list"
# TIKTOK_DISCOVERY_ENDPOINT="https://open.tiktokapis.com/v2/"
# TIKTOK_VIDEO_FIELDS="id,title,video_description,duration,cover_image_url,share_url"

# KLING 연동 (선택)
# KLING_ACCESS_KEY="your_kling_access_key"
# KLING_SECRET_KEY="your_kling_secret_key"
# (구버전 단일 토큰 사용 시)
# KLING_API_TOKEN="legacy_kling_token"
